public class Main {
    public static void main(String[] args) {

        int[] a = {0, 2, 1, 3, 0, 6, 0};
        int[] b = new int[a.length];
        int index = 0;
        for (int i = 0; i < a.length; i++) {
            if (a[i] != 0) {
                b[index] = a[i];
                index++;
            }
        }
        for (int i = 0; i < b.length; i++) {
            System.out.print(b[i]);
        }
    }
}
