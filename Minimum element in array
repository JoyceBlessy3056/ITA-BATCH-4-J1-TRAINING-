import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int size = sc.nextInt();
        int arr[] = new int[size];
        arr[0] = sc.nextInt();
        int min = arr[0];
        for (int i = 1; i < size; i++) {
            arr[i] = sc.nextInt();
            if (arr[i] < min) {
                min = arr[i];
            }
        }
        System.out.print("Minimum element in array is " + min);
    }
}
