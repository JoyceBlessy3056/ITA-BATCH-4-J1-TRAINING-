import java.util.*;
public class Main{
    public static void main(String[]args){
        Scanner sc =new Scanner(System.in);
        int n= sc.nextInt();
        ArrayList<Integer> a=new ArrayList<>();
        for(int i=0;i<n;i++){
            a.add(sc.nextInt());
        }
        ArrayList<Integer>rev=new ArrayList<>();
        for(int i=n-1;i>=0;i--){
            rev.add(a.get(i));
        }
        System.out.print(rev);
}
}
