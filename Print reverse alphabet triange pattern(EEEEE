import java.util.*;
public class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
         int a=69;
       for(int i=n;i>=1;i--){
           for(int j=1;j<=i;j++){
               for(int k=a;k<=a;k++){
                   System.out.print((char)k+" ");
               }
           }
           System.out.println();
            a--;
       }
    }
}
